{
  "name": "simplexweb",
  "description": "SimpleWebPlayer - Modern music player with collaborative rooms and Telegram bot",
  "repository": "https://github.com/superboygisan/simple_webm",
  "keywords": [
    "music",
    "player",
    "telegram",
    "flask",
    "socketio"
  ],
  "env": {
    "BOT_TOKEN": {
      "description": "Telegram Bot Token",
      "required": true
    },
    "SECRET_KEY": {
      "description": "Secret key",
      "generator": "secret"
    },
    "WEBAPP_URL": {
      "description": "Your Heroku App URL",
      "required": true
    },
    "OWNER_ID": {
      "description": "Telegram User ID",
      "required": true
    },
    "OWNER_USERNAME": {
      "description": "Telegram Username",
      "required": true
    },
    "FLASK_DEBUG": {
      "description": "Enable Debug",
      "value": "false"
    }
  },
  "buildpacks": [
    {
      "url": "heroku/python"
    }
  ]
}